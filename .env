# ====================================================================
# NEXUS AI TRADING TERMINAL CONFIGURATION
# ====================================================================

# [Security] Password protection for the UI (Optional)
# If set, access to the trading terminal will require entering this password.
# Leave empty to disable password authentication.
APP_PASSWORD=

# [Network] Flet App Host and Port
HOST=0.0.0.0
PORT=8550

# [UI Mode] Flet View Mode
# Set to 1 to run as a web server accessible from browser/mobile.
# Set to 0 to launch as a standalone desktop application window.
FLET_WEB_MODE=0

# [Binance] Region configuration
# Set to True if using binance.us endpoints.
USE_BINANCE_US=False

# [Network] Global HTTP Proxy for Binance API connection (Optional)
# Format: http://username:password@ip:port or http://ip:port
BINANCE_PROXY=
