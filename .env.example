# [Security] Password protection for the UI (Optional)
APP_PASSWORD=

# [Network] Flet App Host and Port
HOST=0.0.0.0
PORT=8550

# [UI Mode] Flet View Mode (1 for Web, 0 for Desktop)
FLET_WEB_MODE=0

# [Binance] Region configuration
USE_BINANCE_US=False

# [Network] Global HTTP Proxy for Binance API connection (Optional)
# Format: http://username:password@ip:port
BINANCE_PROXY=
